# =============================================================================
# DoisB Sistemas — Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (e-mails transacionais) ---
RESEND_API_KEY=re_...

# --- Anthropic Claude (chat IA / suporte) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (embeddings via pgvector) ---
OPENAI_API_KEY=sk-...

# --- Google Places (validação de endereço de clientes) ---
GOOGLE_PLACES_API_KEY=AIza...

# --- URL pública do site ---
NEXT_PUBLIC_SITE_URL=https://doisbsistemas.com.br
